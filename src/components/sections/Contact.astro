---
import { contact } from '../../data/home';
const action = `https://formspree.io/f/${contact.formspreeId}`;
---

<section id="contact" class="mt-16 scroll-mt-24">
  <p class="label">Contact</p>
  <h2 class="mt-2 font-display text-2xl font-semibold">Get in touch</h2>
  <p class="mt-2 max-w-2xl text-ink-soft">{contact.content}</p>

  <form action={action} method="POST" class="mt-6 grid max-w-xl gap-4">
    <div>
      <label for="contact-email" class="label">Your email</label>
      <input
        id="contact-email"
        type="email"
        name="email"
        required
        class="mt-1 w-full rounded-sm border border-ink bg-panel px-4 py-2.5 text-sm focus:border-accent focus:outline-none"
      />
    </div>
    <div>
      <label for="contact-message" class="label">Message</label>
      <textarea
        id="contact-message"
        name="message"
        rows="5"
        required
        class="mt-1 w-full rounded-sm border border-ink bg-panel px-4 py-2.5 text-sm focus:border-accent focus:outline-none"
      ></textarea>
    </div>
    <div>
      <button type="submit" class="rounded-full bg-ink px-6 py-2.5 text-sm font-medium text-paper transition hover:bg-accent">
        Send message
      </button>
    </div>
  </form>
</section>
