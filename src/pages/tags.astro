---
import Base from '../layouts/Base.astro';
import { allTags, tagSlug } from '../lib/tags';

const topics = allTags('topic');
const tech = allTags('tech');
---

<Base title="Topics · Matty Stratton" description="Browse Matty Stratton's talks by topic and technology." image="/og/talks.png">
  <header class="border-b-2 border-ink pb-6">
    <p class="label">Browse by subject</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">Topics</h1>
    <p class="label mt-3 normal-case tracking-normal text-ink-soft">
      {topics.length} topics · {tech.length} technologies
    </p>
  </header>

  <section class="mt-10">
    <h2 class="font-display text-2xl font-semibold text-accent">Topics</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {topics.map((t) => (
        <a
          href={`/tag/${t.slug}`}
          class="label normal-case tracking-normal inline-flex items-center gap-1.5 rounded-full border border-rule px-3 py-1.5 text-ink transition-colors hover:border-accent hover:text-accent"
        >
          {t.name}
          <span class="font-mono text-xs text-ink-soft">{t.count}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="font-display text-2xl font-semibold text-accent">Technology</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {tech.map((t) => (
        <a
          href={`/tag/${t.slug}`}
          class="inline-flex items-center gap-1.5 rounded-full bg-ink/5 px-3 py-1.5 font-mono text-sm text-ink transition-colors hover:bg-accent/10 hover:text-accent"
        >
          <span class="text-ink/30">#</span>{t.name}
          <span class="text-xs text-ink-soft">{t.count}</span>
        </a>
      ))}
    </div>
  </section>
</Base>
