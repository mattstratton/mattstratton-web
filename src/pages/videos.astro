---
import { getCollection, getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';

const talks = (await getCollection('talks'))
  .filter((t) => t.data.video)
  .sort((a, b) => b.data.presentedOn.getTime() - a.data.presentedOn.getTime());

// Resolve event + poster per video. YouTube exposes a thumbnail; Vimeo falls
// back to the talk thumbnail (or a plain panel).
const items = await Promise.all(
  talks.map(async (t) => {
    const event = t.data.event ? await getEntry(t.data.event) : null;
    const v = t.data.video!;
    const poster =
      v.provider === 'youtube'
        ? `https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`
        : t.data.thumbnail;
    return {
      href: `/${t.data.notistId}/${t.data.notistSlug}`,
      title: t.data.title,
      event: event?.data.name,
      year: t.data.presentedOn.getFullYear(),
      poster,
    };
  }),
);
---

<Base
  title="Videos — Matty Stratton"
  description={`Watch ${items.length} recorded talks from Matty Stratton.`}
>
  <header class="border-b-2 border-ink pb-6">
    <p class="label">Watch</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">Talks on video</h1>
    <p class="mt-3 max-w-xl text-ink-soft">
      {items.length} recorded talks. Click through to watch — the player loads only when you hit play.
    </p>
  </header>

  <ul class="mt-8 grid grid-cols-1 gap-x-6 gap-y-9 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((v) => (
      <li>
        <a href={v.href} class="group block">
          <div class="relative aspect-video overflow-hidden rounded-md bg-ink ring-1 ring-rule">
            {v.poster ? (
              <img
                src={v.poster}
                alt=""
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center font-display text-3xl text-paper/40" aria-hidden="true">▶</div>
            )}
            <span class="absolute inset-0 bg-ink/10 transition group-hover:bg-ink/0"></span>
            <span class="absolute bottom-3 left-3 flex h-11 w-11 items-center justify-center rounded-full bg-accent-bright text-white shadow-lg transition group-hover:scale-110">
              <svg viewBox="0 0 24 24" fill="currentColor" class="ml-0.5 h-5 w-5" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
            </span>
          </div>
          <h2 class="mt-3 font-display text-lg font-medium leading-snug text-balance decoration-accent-bright decoration-2 underline-offset-4 group-hover:underline">
            {v.title}
          </h2>
          <p class="label mt-1 normal-case tracking-normal">
            {v.event && <span class="text-ink">{v.event}</span>}<span class="text-ink-soft"> · {v.year}</span>
          </p>
        </a>
      </li>
    ))}
  </ul>
</Base>
