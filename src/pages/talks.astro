---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TalkCard from '../components/TalkCard.astro';

const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.presentedOn.getTime() - a.data.presentedOn.getTime(),
);

const byYear = new Map<number, typeof talks>();
for (const talk of talks) {
  const y = talk.data.presentedOn.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(talk);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Talks · Matty Stratton" description={`Every talk Matty Stratton has given. ${talks.length} of them, going back to ${years.at(-1)}.`}>
  <header class="border-b-2 border-ink pb-6">
    <p class="label">Every talk, ever</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">Talks</h1>
    <p class="label mt-3 normal-case tracking-normal text-ink-soft">
      {talks.length} talks · {years.at(-1)}–{years[0]}
    </p>
  </header>

  <nav class="sticky top-0 z-10 -mx-5 mt-0 flex flex-wrap gap-1.5 border-b border-rule bg-paper/90 px-5 py-3 backdrop-blur" aria-label="Jump to year">
    {years.map((y) => (
      <a href={`#${y}`} class="label rounded-full border border-rule px-2.5 py-1 transition-colors hover:border-accent hover:text-accent">{y}</a>
    ))}
  </nav>

  {years.map((y) => (
    <section class="mt-10 scroll-mt-16" id={String(y)}>
      <div class="flex items-baseline gap-3">
        <h2 class="font-display text-3xl font-semibold text-accent">{y}</h2>
        <span class="label">{byYear.get(y)!.length} {byYear.get(y)!.length === 1 ? 'talk' : 'talks'}</span>
      </div>
      <div class="mt-2 border-t-2 border-ink">
        {byYear.get(y)!.map((talk) => <TalkCard talk={talk} />)}
      </div>
    </section>
  ))}
</Base>
