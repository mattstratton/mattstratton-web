---
import Base from './Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { PARTS } from '../lib/writing';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'writing'>;
}
const { entry } = Astro.props;
const d = entry.data;
const partLabel = d.part ? PARTS.find((p) => p.key === d.part)?.label : null;
const pub = d.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updated = d.updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title={`${d.title} · Matty Stratton`}
  description={d.description}
  type="article"
  publishedTime={d.pubDate.toISOString()}
  canonicalUrl={d.canonicalUrl}
  image={`/og/writing/${entry.id}.png`}
>
  <article class="mx-auto max-w-2xl">
    <header class="border-b-2 border-ink pb-6">
      {partLabel && <p class="label">{partLabel}</p>}
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight text-balance sm:text-5xl">
        {d.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-soft">{d.description}</p>
      <p class="label mt-5 normal-case tracking-normal">
        <time datetime={d.pubDate.toISOString()}>{pub}</time>
        {updated && <span> · Updated {updated}</span>}
      </p>
      {d.canonicalUrl && (
        <p class="mt-3 text-sm text-ink-soft">
          Originally published at <a href={d.canonicalUrl} rel="noopener" class="text-accent hover:underline">{new URL(d.canonicalUrl).hostname}</a>.
        </p>
      )}
    </header>

    <div class="prose prose-lg mt-8 max-w-none">
      <slot />
    </div>

    {d.topics.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-2 border-t border-rule pt-6">
        {d.topics.map((t) => (
          <span class="rounded-full bg-ink/5 px-3 py-1 text-sm ring-1 ring-rule">{t}</span>
        ))}
      </div>
    )}
  </article>

  <div class="mx-auto max-w-2xl">
    <Newsletter />
  </div>
</Base>
