---
import Base from './Base.astro';
import { slugify } from '../lib/posts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const d = post.data;
const date = d.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title={`${d.title} · Matty Stratton`}
  description={d.description}
  type="article"
  publishedTime={d.date.toISOString()}
>
  <article class="mx-auto max-w-2xl" data-pagefind-body>
    <header class="border-b-2 border-ink pb-6">
      <p class="label" data-pagefind-ignore>From the archive</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight text-balance sm:text-5xl">
        {d.title}
      </h1>
      <p class="label mt-4 normal-case tracking-normal">
        <time datetime={d.date.toISOString()}>{date}</time>
        {d.author && <span> · {d.author}</span>}
      </p>
    </header>

    {d.image && !d.heroInBody && (
      <img
        src={d.image}
        alt={d.title}
        loading="eager"
        decoding="async"
        class="mt-8 w-full rounded-sm object-cover ring-1 ring-rule"
      />
    )}

    <div class="prose prose-lg mt-8 max-w-none">
      <slot />
    </div>

    {(d.categories.length > 0 || d.tags.length > 0) && (
      <footer class="mt-10 flex flex-wrap gap-2 border-t border-rule pt-6">
        {d.categories.map((c) => (
          <a href={`/categories/${slugify(c)}/`} class="rounded-full bg-accent/10 px-3 py-1 text-sm text-accent ring-1 ring-accent/20 transition hover:bg-accent/20">{c}</a>
        ))}
        {d.tags.map((t) => (
          <a href={`/tags/${slugify(t)}/`} class="rounded-full bg-ink/5 px-3 py-1 text-sm ring-1 ring-rule transition hover:ring-accent">{t}</a>
        ))}
      </footer>
    )}

    <p class="mt-8">
      <a href="/post/" class="label transition-colors hover:text-accent">← All posts</a>
    </p>
  </article>
</Base>
