# build output
dist/
.astro/

# deps
node_modules/

# ingest cache (raw Notist responses; re-fetchable, not committed)
scripts/.cache/

# full-res original PDFs (bloated Notist exports) — the durable archive, NOT committed.
# slides/{id}.pdf is the 300dpi web-optimized version derived from these (see ingest).
originals/

# NOTE: public/slides/ IS committed and served — it holds both the optimized
# PDFs ({id}.pdf, generated by optimize) and the rasterized WebP ({id}/{n}.webp,
# generated by rasterize), produced locally pre-commit so the deploy needs no
# poppler/gs. Image-only PNG sources (slides/{id}/*.png) are committed too.

# os / editor
.DS_Store
*.log
.env
.env.*

# Local Netlify folder
.netlify
