---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TalkCard from '../../components/TalkCard.astro';
import { groupTalks } from '../../lib/talk-groups';
import { allTags, tagBySlug, talkSlugsForTag } from '../../lib/tags';

// One page per tag (topic or tech), listing the canonical talks that carry it.
// Cards link to /talk/{slug} (the abstract), not a single delivery.
export async function getStaticPaths() {
  const groups = groupTalks(await getCollection('talks'));
  return allTags().map((tag) => {
    const slugs = talkSlugsForTag(tag.slug);
    const talks = [...groups.values()]
      .filter((g) => slugs.has(g.slug))
      .sort((a, b) => b.deliveries[0].data.presentedOn.getTime() - a.deliveries[0].data.presentedOn.getTime());
    return { params: { slug: tag.slug }, props: { tag, talks } };
  });
}

const { tag, talks } = Astro.props;
const kindLabel = tag.kind === 'tech' ? 'Technology' : 'Topic';
const description = `${talks.length} ${tag.name} talk${talks.length === 1 ? '' : 's'} by Matty Stratton.`;
---

<Base
  title={`${tag.name} · Matty Stratton`}
  description={description}
  image={`/og/tag/${tag.slug}.png`}
  imageAlt={`${tag.name} — talks by Matty Stratton`}
>
  <article class="mx-auto max-w-3xl">
    <a href="/tags" class="label transition-colors hover:text-accent">← All topics</a>

    <header class="mt-4 border-b-2 border-ink pb-6">
      <p class="label">{kindLabel}</p>
      <h1 class="mt-2 font-display text-3xl font-semibold tracking-tight sm:text-4xl">
        {tag.kind === 'tech' && <span class="text-ink/30">#</span>}{tag.name}
      </h1>
      <p class="label mt-3 normal-case tracking-normal text-ink-soft">
        {talks.length} {talks.length === 1 ? 'talk' : 'talks'}
      </p>
    </header>

    <div class="mt-2 border-t-2 border-ink">
      {talks.map((g) => <TalkCard talk={g.deliveries[0]} href={`/talk/${g.slug}`} />)}
    </div>
  </article>
</Base>
