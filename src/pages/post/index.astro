---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { groupByYear } from '../../lib/posts';

const posts = await getCollection('posts');
const byYear = groupByYear(posts);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Base
  title="Archive · Matty Stratton"
  description="Twenty-five years of personal blogging, from 2001 onward. The full archive."
>
  <section class="border-b-2 border-ink pb-8">
    <p class="label">The archive</p>
    <h1 class="mt-4 font-display text-5xl font-semibold leading-[0.95] tracking-tight text-balance">
      {posts.length.toLocaleString()} posts, back to 2001
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
      A quarter-century of personal writing — kept exactly as it was. Dig in by year, or browse by
      <a href="/categories/" class="text-accent hover:underline">category</a> and
      <a href="/tags/" class="text-accent hover:underline">tag</a>.
    </p>
    <nav class="mt-6 flex flex-wrap gap-x-3 gap-y-1" aria-label="Jump to year">
      {byYear.map(([year]) => (
        <a href={`#y${year}`} class="label transition-colors hover:text-accent">{year}</a>
      ))}
    </nav>
  </section>

  {byYear.map(([year, yearPosts]) => (
    <section id={`y${year}`} class="mt-10 scroll-mt-20">
      <h2 class="font-display text-3xl font-semibold tabular-nums">{year}</h2>
      <ul class="mt-3">
        {yearPosts.map((p) => (
          <li class="flex gap-4 border-b border-rule py-2.5">
            <span class="label w-16 shrink-0 normal-case tracking-normal text-ink-soft">{fmt(p.data.date)}</span>
            <a href={`/${p.data.permalink}/`} class="decoration-accent-bright decoration-2 underline-offset-4 hover:underline">{p.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>
