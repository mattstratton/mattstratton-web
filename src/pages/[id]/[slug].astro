---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SlideBrowser from '../../components/SlideBrowser.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import slideCounts from '../../data/slide-counts.json';

// URL parity with Notist: /{notistId}/{slug}. The id segment is the stable key
// every inbound link uses; the slug must match what Notist served.
export async function getStaticPaths() {
  const talks = await getCollection('talks');
  // Emit lowercase URL paths: Netlify force-301s mixed-case to lowercase, so the
  // site's own routes/links/sitemap point at the canonical lowercase form (200).
  // Only legacy mixed-case Notist inbound links take the (unavoidable) redirect.
  // Asset paths keep the original-case notistId (files serve fine case-insensitively).
  return talks.map((talk) => ({
    params: { id: talk.data.notistId.toLowerCase(), slug: talk.data.notistSlug },
    props: { talk },
  }));
}

const { talk } = Astro.props;
const d = talk.data;

const event = d.event ? await getEntry(d.event) : null;

// Slide count comes from the build-time rasterizer manifest; fall back to the
// ingest-recorded image count, then to none.
const slideCount = (slideCounts as Record<string, number>)[d.notistId] ?? d.slideImageCount ?? 0;

const presented = d.presentedOn.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Plain-text abstract for meta description.
const description = d.abstractHtml
  ? d.abstractHtml.replace(/<[^>]+>/g, '').slice(0, 200)
  : `${d.title} by Matty Stratton.`;
---

<Base
  title={`${d.title} · Matty Stratton`}
  description={description}
  image={`/og/talks/${d.notistId.toLowerCase()}.png`}
  imageAlt={`${d.title} — Matty Stratton`}
  type="article"
  publishedTime={d.presentedOn.toISOString()}
>
  <article class="mx-auto max-w-3xl">
    <a href="/talks" class="label transition-colors hover:text-accent">← All talks</a>

    <header class="mt-4 border-b-2 border-ink pb-6">
      <h1 class="font-display text-3xl font-semibold leading-tight tracking-tight text-balance sm:text-4xl">{d.title}</h1>
      <p class="label mt-3 normal-case tracking-normal">
        {event && (
          <>
            {event.data.url ? (
              <a href={event.data.url} class="text-ink underline decoration-rule underline-offset-2 hover:decoration-accent" rel="noopener">{event.data.name}</a>
            ) : (
              <span class="text-ink">{event.data.name}</span>
            )}
            <span class="text-ink-soft"> · </span>
          </>
        )}
        <time class="text-ink-soft" datetime={d.presentedOn.toISOString()}>{presented}</time>
        {event?.data.location && <span class="text-ink-soft"> · {event.data.location}</span>}
      </p>
    </header>

    {d.video && <VideoEmbed provider={d.video.provider} id={d.video.id} title={d.title} />}

    {slideCount > 0 && (
      <SlideBrowser id={d.notistId} slideCount={slideCount} title={d.title} slidesPdf={d.slidesPdf} />
    )}

    {d.abstractHtml && (
      <div class="prose prose-lg mt-8 max-w-none" set:html={d.abstractHtml} />
    )}

    {d.resources.length > 0 && (
      <section class="mt-10 border-t border-rule pt-6">
        <h2 class="label">Resources</h2>
        <ul class="mt-3 space-y-2">
          {d.resources.map((r) => (
            <li>
              <a href={r.url} class="text-accent underline decoration-rule underline-offset-2 hover:decoration-accent-bright" rel="noopener">{r.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>
