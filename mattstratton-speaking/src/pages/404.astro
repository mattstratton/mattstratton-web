---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found · Matty Stratton"
  description="That page doesn't exist (or moved). Head back to the talks."
  is404
>
  <header class="border-b-2 border-ink pb-6">
    <p class="label">404</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">Page not found</h1>
    <p class="mt-3 text-ink-soft">
      That page doesn't exist, or it moved when this site left Notist.
    </p>
  </header>

  <section class="mt-10">
    <p class="text-ink">
      Try one of these instead:
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      <a href="/talks" class="label inline-flex items-center rounded-full border border-rule px-3 py-1.5 text-ink transition-colors hover:border-accent hover:text-accent">All talks</a>
      <a href="/tags" class="label inline-flex items-center rounded-full border border-rule px-3 py-1.5 text-ink transition-colors hover:border-accent hover:text-accent">Topics</a>
      <a href="/videos" class="label inline-flex items-center rounded-full border border-rule px-3 py-1.5 text-ink transition-colors hover:border-accent hover:text-accent">Videos</a>
      <a href="/" class="label inline-flex items-center rounded-full border border-rule px-3 py-1.5 text-ink transition-colors hover:border-accent hover:text-accent">Home</a>
    </div>
  </section>
</Base>
